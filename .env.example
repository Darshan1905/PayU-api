APP_NAME="PayU Middleware"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=payu_api
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log

# PayU Middleware API — IP whitelist for /api/payu/*
API_IP_WHITELIST_ENABLED=true
API_ALLOWED_IPS=127.0.0.1,::1

# Proxy mode (recommended): Laravel → WordPress → PayU
PAYU_PROXY_URL=https://pavokart.com
PAYU_PROXY_SECRET=change-me-to-match-wp-plugin
PAYU_WP_LOG_ENABLED=true
PAYU_WP_LOG_URL=https://pavokart.com/wp-json/payu/v1/log-ingest
PAYU_WP_LOG_SECRET=

# PayU production (only needed for direct mode without proxy)
PAYU_API_BASE=https://api.payu.in
PAYU_POSTSERVICE_URL=https://info.payu.in/merchant/postservice?form=2
PAYU_MERCHANT_KEY=
PAYU_MERCHANT_SALT=
PAYU_MERCHANT_MID=13678525

# PayU server webhook
PAYU_CALLBACK_URL=https://connect.pavokart.com/webhook/payu

# PayU return handlers (automatic — leave as-is unless custom)
PAYU_RETURN_SUCCESS_URL=https://connect.pavokart.com/payu/return/success
PAYU_RETURN_FAILURE_URL=https://connect.pavokart.com/payu/return/failure

# Customer-facing pages (hosted on connect.pavokart.com)
PAYU_SUCCESS_REDIRECT_URL=https://connect.pavokart.com/payment/success
PAYU_FAILURE_REDIRECT_URL=https://connect.pavokart.com/payment/failed
PAYU_SHOP_URL=https://pavokart.com

# Mswipe PBL (same WordPress site, separate plugin routes)
MSWIPE_PROXY_URL=https://pavokart.com
MSWIPE_PROXY_SECRET=change-me-to-match-wp-plugin
MSWIPE_WP_LOG_ENABLED=true
MSWIPE_WP_LOG_URL=https://pavokart.com/wp-json/mswipe/v1/log-ingest
MSWIPE_WP_LOG_SECRET=
MSWIPE_ENVIRONMENT=uat
MSWIPE_CALLBACK_URL=http://127.0.0.1:8000/webhook/mswipe
